# Database Connection URL (PostgreSQL)
DATABASE_URL="postgresql://username:password@localhost:5432/dbname?sslmode=require"

# JWT Secret for Signing and Verification (Use a secure, random string in production)
JWT_SECRET="generate_a_secure_random_string_here"

# Server Port (Default is 5000)
PORT=5000

# Client Application URL (For CORS validation)
CLIENT_URL="http://localhost:3000"

# Application Environment (development or production)
NODE_ENV="development"
